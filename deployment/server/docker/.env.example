# Vord Fleet — Docker Compose Environment Variables
# Copy this file to .env and fill in all values.

# Container image tag (e.g., "1.3.5" or "latest")
IMAGE_TAG=latest

# Database
DB_USER=vordfleet
DB_PASSWORD=CHANGE_ME
DB_NAME=vordfleet

# Exposed ports (host:container defaults shown)
API_HTTP_PORT=12233
API_GRPC_PORT=12234
WEB_PORT=5254

# CORS & App (set to your domain, or http://localhost:5254 for local testing)
CORS_ORIGIN=http://localhost:5254
APP_BASE_URL=http://localhost:5254

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — Microsoft
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OIDC (SSO) — only needed if configuring a custom OIDC provider
OIDC_AUTHORITY=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_METADATA_ADDRESS=

# Billing integration (set to true for SaaS deployment with Stripe billing API)
Billing__Enabled=false

# Subscription defaults (self-hosters: increase these for your deployment)
FREE_TIER_MACHINE_LIMIT=3
FREE_TIER_RETENTION_DAYS=1

# Email (Resend) — optional, invitations won't send without it
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Cookie domain (set if running on a custom domain, e.g., .example.com)
# AUTH_COOKIE_DOMAIN=
