{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "FastEndpoints": "Warning",
            "Microsoft.AspNetCore.*": "Warning",
            "Microsoft.EntityFrameworkCore.*": "Warning",
            "Microsoft.Extensions.*": "Warning"
        }
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.Extensions": "Warning",
                "FastEndpoints": "Warning",
                "System.Net.Http": "Warning",
                "LinqToDB": "Warning"
            }
        }
    },
    "Telemetry": {
        "RetentionDays": 90
    },
    "TierDefaults": {
        "Free": {
            "MachineLimit": 3,
            "RetentionDays": 1,
            "AlertRuleLimit": 0,
            "WebhookLimit": 0
        },
        "Pro": {
            "MachineLimit": 1000,
            "RetentionDays": 60,
            "AlertRuleLimit": 10,
            "WebhookLimit": 5
        },
        "Team": {
            "MachineLimit": 10000,
            "RetentionDays": 365,
            "AlertRuleLimit": 25,
            "WebhookLimit": 15
        }
    },
    "ServerDefaults": {
        "AgentHeartbeatSeconds": 300,
        "AgentConfigRefreshSeconds": 21600,
        "OnlineThresholdSeconds": 300,
        "CertificateExpiryWarningDays": 30,
        "DeduplicationTtlSeconds": 300
    }
}
